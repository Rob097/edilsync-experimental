{
  "name": "AppFeature",
  "type": "object",
  "properties": {
    "feature_key": {
      "type": "string",
      "description": "Stable feature identifier"
    },
    "scope_type": {
      "type": "string",
      "enum": [
        "company",
        "project"
      ],
      "description": "Feature scope"
    },
    "name": {
      "type": "string",
      "description": "Human readable feature name"
    },
    "description": {
      "type": "string",
      "description": "Feature description"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Ordering field for UI and documentation"
    }
  },
  "required": [
    "feature_key",
    "scope_type",
    "name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}