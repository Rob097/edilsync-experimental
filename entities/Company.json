{
  "name": "Company",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Company legal name"
    },
    "vat_number": {
      "type": "string",
      "description": "VAT number / P.IVA"
    },
    "address": {
      "type": "string",
      "description": "Company address"
    },
    "phone": {
      "type": "string",
      "description": "Contact phone"
    },
    "email": {
      "type": "string",
      "description": "Contact email"
    },
    "description": {
      "type": "string",
      "description": "Company description"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": true,
    "read": true,
    "update": {
      "$or": [
        {
          "id": {
            "$in": "{{user.data.admin_company_ids}}"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "id": {
            "$in": "{{user.data.admin_company_ids}}"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    }
  }
}