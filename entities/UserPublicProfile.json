{
  "name": "UserPublicProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Reference to User"
    },
    "user_email": {
      "type": "string",
      "description": "User email for lookup"
    },
    "display_name": {
      "type": "string",
      "description": "Public display name"
    },
    "full_name": {
      "type": "string",
      "description": "Full name fallback"
    },
    "avatar_url": {
      "type": "string",
      "description": "Public avatar URL"
    }
  },
  "required": [
    "user_id",
    "user_email"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}