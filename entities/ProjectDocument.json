{
  "name": "ProjectDocument",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Reference to Project (optional if company_id is set)"
    },
    "company_id": {
      "type": "string",
      "description": "Reference to Company (optional if project_id is set)"
    },
    "name": {
      "type": "string",
      "description": "Document name"
    },
    "description": {
      "type": "string",
      "description": "Optional description"
    },
    "file_url": {
      "type": "string",
      "description": "URL of the uploaded file"
    },
    "file_path": {
      "type": "string",
      "description": "Path in storage bucket used for signed URL access"
    },
    "file_type": {
      "type": "string",
      "description": "File extension/type (pdf, jpg, dwg, etc.)"
    },
    "file_size": {
      "type": "number",
      "description": "File size in bytes"
    },
    "uploaded_by_email": {
      "type": "string",
      "description": "Email of the user who uploaded"
    },
    "uploaded_by_name": {
      "type": "string",
      "description": "Name of the user who uploaded"
    },
    "category": {
      "type": "string",
      "enum": [
        "project",
        "contract",
        "permit",
        "drawing",
        "photo",
        "report",
        "other"
      ],
      "description": "Document category"
    },
    "parent_document_id": {
      "type": "string",
      "description": "Previous revision id when this document is a substitution"
    },
    "root_document_id": {
      "type": "string",
      "description": "Revision chain root document id"
    },
    "revision_number": {
      "type": "number",
      "description": "Progressive revision number"
    },
    "is_current_revision": {
      "type": "boolean",
      "description": "True for the latest active revision"
    },
    "document_status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "approved",
        "rejected",
        "superseded",
        "archived"
      ],
      "description": "Document lifecycle status"
    },
    "discipline": {
      "type": "string",
      "description": "Design discipline (architecture, structure, mep, etc.)"
    },
    "work_area": {
      "type": "string",
      "description": "Project area or object (room, foundation, section, etc.)"
    },
    "project_phase": {
      "type": "string",
      "description": "Design phase (concept, executive, as-built, etc.)"
    },
    "document_tags": {
      "type": "array",
      "description": "Flexible user tags for search and filtering"
    },
    "model_format": {
      "type": "string",
      "enum": [
        "ifc",
        "glb",
        "gltf",
        "other"
      ],
      "description": "3D/BIM model format when applicable"
    }
  },
  "required": [
    "name",
    "file_url"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "project_id": {
            "$in": "{{user.data.project_ids}}"
          }
        },
        {
          "company_id": {
            "$in": "{{user.data.company_ids}}"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "read": {
      "$or": [
        {
          "project_id": {
            "$in": "{{user.data.project_ids}}"
          }
        },
        {
          "company_id": {
            "$in": "{{user.data.company_ids}}"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}